{
  "expo": {
    "name": "GlucoApp",
    "slug": "glucoapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "glucoapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-background.png",
      "resizeMode": "cover",
      "backgroundColor": "#EEF4FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.glucoapp.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSHealthShareUsageDescription": "O GlucoApp usa dados de saúde para exibir suas leituras de glicose.",
        "NSHealthUpdateUsageDescription": "O GlucoApp salva suas leituras de glicose no HealthKit.",
        "NSMotionUsageDescription": "Usado para detectar atividade física relacionada ao controle glicêmico.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.glucoapp.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "SEU_PROJECT_ID_AQUI"
      }
    }
  }
}
